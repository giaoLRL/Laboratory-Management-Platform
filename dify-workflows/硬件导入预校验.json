{
  "app": {
    "name": "硬件导入预校验",
    "description": "两段式导入-预校验",
    "mode": "workflow"
  },
  "workflow": {
    "graph": {
      "nodes": [
        {
          "id": "start",
          "type": "start",
          "data": {
            "title": "开始",
            "type": "start",
            "variables": [
              {
                "variable": "user_query",
                "label": "user_query",
                "type": "text-input",
                "required": true
              }
            ],
            "selected": false
          },
          "position": {
            "x": 80,
            "y": 282
          },
          "positionAbsolute": {
            "x": 80,
            "y": 282
          },
          "width": 150,
          "height": 22
        },
        {
          "id": "llm1",
          "type": "llm",
          "data": {
            "title": "解析导入数据",
            "type": "llm",
            "model": {
              "provider": "langgenius/openai_api_compatible/openai_api_compatible",
              "name": "deepseek-chat",
              "mode": "chat",
              "completion_params": {
                "temperature": 0.7
              }
            },
            "prompt_template": [
              {
                "role": "system",
                "text": "从用户输入中解析硬件清单，输出JSON：{\"source_type\": \"json\", \"import_action\": \"validate\", \"items\": [{\"name\": \"...\", \"category\": \"...\", \"quantity\": N}]}\n用户输入：{{#start.user_query#}}"
              }
            ],
            "memory": null,
            "context": {
              "enabled": false
            },
            "selected": true
          },
          "position": {
            "x": 380,
            "y": 282
          },
          "positionAbsolute": {
            "x": 380,
            "y": 282
          },
          "width": 150,
          "height": 22,
          "selected": true
        },
        {
          "id": "http1",
          "type": "http-request",
          "data": {
            "title": "预校验",
            "type": "http-request",
            "method": "post",
            "url": "http://172.22.96.1:8000/plugins/lab-manager/api/agent/hardware/import/validate/",
            "headers": "Content-Type: application/json\nX-Agent-Source: dify-workflow\nX-Agent-Token: lab-manager-internal-token-change-me\nX-Request-ID: {{#sys.request_id#}}\nX-User-ID: 1",
            "body": "{{#llm1.text#}}",
            "authorization": {
              "type": "no-auth"
            },
            "timeout": {
              "connect": 10,
              "read": 60,
              "write": 20
            },
            "retry_config": {
              "retry_enabled": true,
              "max_retries": 3,
              "retry_interval": 100
            },
            "selected": false
          },
          "position": {
            "x": 680,
            "y": 282
          },
          "positionAbsolute": {
            "x": 680,
            "y": 282
          },
          "width": 150,
          "height": 22
        },
        {
          "id": "llm2",
          "type": "llm",
          "data": {
            "title": "展示校验结果",
            "type": "llm",
            "model": {
              "provider": "langgenius/openai_api_compatible/openai_api_compatible",
              "name": "deepseek-chat",
              "mode": "chat",
              "completion_params": {
                "temperature": 0.7
              }
            },
            "prompt_template": [
              {
                "role": "system",
                "text": "向用户展示校验结果：批次ID、通过/重复/错误数量，询问是否确认导入。\n校验结果：{{#http1.body#}}"
              }
            ],
            "memory": null,
            "context": {
              "enabled": false
            },
            "selected": false
          },
          "position": {
            "x": 980,
            "y": 282
          },
          "positionAbsolute": {
            "x": 980,
            "y": 282
          },
          "width": 150,
          "height": 22
        },
        {
          "id": "end",
          "type": "end",
          "data": {
            "title": "结束",
            "type": "end",
            "outputs": [
              {
                "variable": "result",
                "value_selector": [
                  "llm2",
                  "text"
                ]
              }
            ],
            "selected": false
          },
          "position": {
            "x": 1280,
            "y": 282
          },
          "positionAbsolute": {
            "x": 1280,
            "y": 282
          },
          "width": 150,
          "height": 22
        }
      ],
      "edges": [
        {
          "id": "start-llm1",
          "source": "start",
          "target": "llm1",
          "type": "custom",
          "sourceHandle": "source",
          "targetHandle": "target",
          "data": {
            "sourceType": "start",
            "targetType": "llm"
          }
        },
        {
          "id": "llm1-http1",
          "source": "llm1",
          "target": "http1",
          "type": "custom",
          "sourceHandle": "source",
          "targetHandle": "target",
          "data": {
            "sourceType": "llm",
            "targetType": "http-request"
          }
        },
        {
          "id": "http1-llm2",
          "source": "http1",
          "target": "llm2",
          "type": "custom",
          "sourceHandle": "source",
          "targetHandle": "target",
          "data": {
            "sourceType": "http-request",
            "targetType": "llm"
          }
        },
        {
          "id": "llm2-end",
          "source": "llm2",
          "target": "end",
          "type": "custom",
          "sourceHandle": "source",
          "targetHandle": "target",
          "data": {
            "sourceType": "llm",
            "targetType": "end"
          }
        }
      ],
      "viewport": {
        "x": 0,
        "y": 100,
        "zoom": 1
      }
    }
  }
}