{
  "app": {
    "name": "任务视频检索",
    "description": "检索已完成任务的视频",
    "mode": "workflow"
  },
  "workflow": {
    "graph": {
      "nodes": [
        {
          "id": "start",
          "type": "start",
          "data": {
            "title": "开始",
            "type": "start",
            "variables": [
              {
                "variable": "user_query",
                "label": "user_query",
                "type": "text-input",
                "required": true
              }
            ]
          },
          "position": {
            "x": 80,
            "y": 282
          },
          "positionAbsolute": {
            "x": 80,
            "y": 282
          }
        },
        {
          "id": "llm1",
          "type": "llm",
          "data": {
            "title": "提取搜索条件",
            "type": "llm",
            "model": {
              "provider": "langgenius/openai_api_compatible/openai_api_compatible",
              "name": "deepseek-chat",
              "mode": "chat",
              "completion_params": {
                "temperature": 0.7
              }
            },
            "prompt_template": [
              {
                "role": "system",
                "text": "今天是 2026-06-22。从用户输入中提取任务搜索条件（keyword只搜索任务标题，不要把视频附件类型作为关键词），输出JSON：{\"assigned_to\": \"\", \"status\": \"completed\", \"keyword\": \"\", \"date_from\": \"\", \"date_to\": \"\", \"limit\": 20}\n用户输入：{{#start.user_query#}}"
              }
            ],
            "memory": null,
            "context": {
              "enabled": false
            }
          },
          "position": {
            "x": 380,
            "y": 282
          },
          "positionAbsolute": {
            "x": 380,
            "y": 282
          }
        },
        {
          "id": "http1",
          "type": "http-request",
          "data": {
            "title": "查询任务",
            "type": "http-request",
            "method": "post",
            "url": "http://172.22.96.1:8000/plugins/lab-manager/api/agent/tasks/search/",
            "headers": "Content-Type: application/json\nX-Agent-Source: dify-workflow\nX-Agent-Token: lab-manager-internal-token-change-me\nX-Request-ID: {{#sys.request_id#}}\nX-User-ID: 1",
            "body": {
              "type": "json",
              "data": [
                {
                  "key": "",
                  "type": "text",
                  "value": "{\"user_query\": \"{{#start.user_query#}}\", \"limit\": 10}"
                }
              ]
            },
            "authorization": {
              "type": "no-auth"
            },
            "timeout": {
              "connect": 10,
              "read": 60,
              "write": 20
            },
            "retry_config": {
              "retry_enabled": true,
              "max_retries": 3,
              "retry_interval": 100
            },
            "params": ""
          },
          "position": {
            "x": 680,
            "y": 282
          },
          "positionAbsolute": {
            "x": 680,
            "y": 282
          }
        },
        {
          "id": "http2",
          "type": "http-request",
          "data": {
            "title": "查询视频",
            "type": "http-request",
            "method": "post",
            "url": "http://172.22.96.1:8000/plugins/lab-manager/api/agent/tasks/videos/",
            "headers": "Content-Type: application/json\nX-Agent-Source: dify-workflow\nX-Agent-Token: lab-manager-internal-token-change-me\nX-Request-ID: {{#sys.request_id#}}\nX-User-ID: 1",
            "body": {
              "type": "json",
              "data": [
                {
                  "key": "",
                  "type": "text",
                  "value": "{{#llm1.text#}}"
                }
              ]
            },
            "authorization": {
              "type": "no-auth"
            },
            "timeout": {
              "connect": 10,
              "read": 60,
              "write": 20
            },
            "retry_config": {
              "retry_enabled": true,
              "max_retries": 3,
              "retry_interval": 100
            },
            "params": ""
          },
          "position": {
            "x": 980,
            "y": 282
          },
          "positionAbsolute": {
            "x": 980,
            "y": 282
          }
        },
        {
          "id": "llm2",
          "type": "llm",
          "data": {
            "title": "汇总输出",
            "type": "llm",
            "model": {
              "provider": "langgenius/openai_api_compatible/openai_api_compatible",
              "name": "deepseek-chat",
              "mode": "chat",
              "completion_params": {
                "temperature": 0.7
              }
            },
            "prompt_template": [
              {
                "role": "system",
                "text": "你是实验室管理员。根据以下查询结果汇总：\n任务列表：{{#http2.body#}}\n视频列表：{{#http2.body#}}"
              }
            ],
            "memory": null,
            "context": {
              "enabled": false
            }
          },
          "position": {
            "x": 1280,
            "y": 282
          },
          "positionAbsolute": {
            "x": 1280,
            "y": 282
          }
        },
        {
          "id": "end",
          "type": "end",
          "data": {
            "title": "结束",
            "type": "end",
            "outputs": [
              {
                "variable": "result",
                "value_selector": [
                  "llm2",
                  "text"
                ]
              }
            ]
          },
          "position": {
            "x": 1580,
            "y": 282
          },
          "positionAbsolute": {
            "x": 1580,
            "y": 282
          }
        }
      ],
      "edges": [
