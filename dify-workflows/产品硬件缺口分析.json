{
  "app": {
    "name": "产品硬件缺口分析",
    "description": "对比需求与库存",
    "mode": "workflow"
  },
  "workflow": {
    "graph": {
      "nodes": [
        {
          "id": "start",
          "type": "start",
          "data": {
            "title": "开始",
            "type": "start",
            "variables": [
              {
                "variable": "user_query",
                "label": "user_query",
                "type": "text-input",
                "required": true
              }
            ]
          }
        },
        {
          "id": "llm1",
          "type": "llm",
          "data": {
            "title": "提取需求",
            "type": "llm",
            "model": {
              "provider": "openai_api_compatible",
              "name": "deepseek-chat",
              "mode": "chat",
              "completion_params": {
                "temperature": 0.7
              }
            },
            "prompt_template": [
              {
                "role": "system",
                "text": "从用户输入中提取项目名称和硬件需求，输出JSON：{\"project_name\": \"...\", \"requirements\": [{\"name\": \"...\", \"category\": \"mcu/sensor/power/instrument/tool/wire/module/other\", \"required_quantity\": N, \"keywords\": [\"...\"]}]}\n用户输入：{{#start.user_query#}}"
              }
            ],
            "memory": null,
            "context": {
              "enabled": false
            }
          }
        },
        {
          "id": "http1",
          "type": "http-request",
          "data": {
            "title": "缺口分析",
            "type": "http-request",
            "method": "post",
            "url": "http://172.22.96.1:8000/plugins/lab-manager/api/agent/hardware/gap-analysis/",
            "headers": "Content-Type: application/json\nX-Agent-Source: dify-workflow\nX-Agent-Token: lab-manager-internal-token-change-me\nX-Request-ID: {{#sys.request_id#}}\nX-User-ID: 1",
            "body": {
              "type": "json",
              "data": [
                {
                  "key": "",
                  "type": "text",
                  "value": "{\"project_description\": \"{{#start.user_query#}}\"}"
                }
              ]
            },
            "authorization": {
              "type": "no-auth"
            },
            "timeout": {
              "connect": 10,
              "read": 60,
              "write": 20
            },
            "params": ""
          }
        },
        {
          "id": "llm2",
          "type": "llm",
          "data": {
            "title": "生成建议",
            "type": "llm",
            "model": {
              "provider": "openai_api_compatible",
              "name": "deepseek-chat",
              "mode": "chat",
              "completion_params": {
                "temperature": 0.7
              }
            },
            "prompt_template": [
              {
                "role": "system",
                "text": "你是实验室采购顾问。根据以下缺口分析结果，生成采购建议和方案说明。\n缺口分析：{{#http1.body#}}"
              }
            ],
            "memory": null,
            "context": {
              "enabled": false
            }
          }
        },
        {
          "id": "end",
          "type": "end",
          "data": {
            "title": "结束",
            "type": "end",
            "outputs": [
              {
                "variable": "result",
                "value_selector": [
                  "llm2",
                  "text"
                ]
              }
            ]
          }
        }
      ],
      "edges": [
        {
          "id": "start-llm1",
          "source": "start",
          "target": "llm1"
        },
        {
          "id": "llm1-http1",
          "source": "llm1",
          "target": "http1"
        },
        {
          "id": "http1-llm2",
          "source": "http1",
          "target": "llm2"
        },
        {
          "id": "llm2-end",
          "source": "llm2",
          "target": "end"
        }
      ]
    }
  }
}