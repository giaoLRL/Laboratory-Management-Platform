                }
              ]
            },
            "timeout": {
              "connect": 10,
              "read": 60,
              "write": 20
            },
            "retry_config": {
              "retry_enabled": true,
              "max_retries": 3,
              "retry_interval": 100
            },
            "selected": true
          },
          "position": {
            "x": 380,
            "y": 282
